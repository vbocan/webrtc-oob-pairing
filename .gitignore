# Generated by make_cert.py — never commit (per-environment)
**/cert.pem
**/key.pem

# Docker testbed persistent state (auto-created on first compose-up)
testbed/tls-proxy/mitmproxy/
testbed/m2-browser-policy/downloads/

# NOTE: evidence/ and *.jsonl ARE committed — they are the measurement data.
# EXCEPT raw mitmproxy flow dumps: large binary captures (mostly browser
# telemetry noise). The curated proxy-evidence.md is committed instead.
evidence/**/flows
evidence/**/*.mitm

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/

# OS / editor
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
